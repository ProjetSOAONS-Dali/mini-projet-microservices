{
  "info": {
    "name": "Microservices E-Commerce — Tests Complets (REST + GraphQL + gRPC)",
    "description": "Collection complète — 35 requêtes couvrant:\n• REST : ProductService, OrderService, NotificationService\n• GraphQL : Queries + Mutations via Apollo\n• gRPC : Tests via grpcurl (ProductService, OrderService, NotificationService)\n\nOrdre recommandé :\n1. REST Products (CRUD)\n2. REST Orders (→ Kafka)\n3. REST Notifications (vérifier Kafka)\n4. GraphQL Queries\n5. GraphQL Mutations\n6. gRPC Direct Tests\n\nURL de base : http://localhost:3000\ngRPC : localhost:50051 (Product) | localhost:50052 (Order) | localhost:50053 (Notification)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL",       "value": "http://localhost:3000" },
    { "key": "GRPC_PRODUCT",   "value": "localhost:50051" },
    { "key": "GRPC_ORDER",     "value": "localhost:50052" },
    { "key": "GRPC_NOTIF",     "value": "localhost:50053" },
    { "key": "PRODUCT_ID",     "value": "p1" },
    { "key": "ORDER_ID",       "value": "" },
    { "key": "CUSTOMER_ID",    "value": "client-001" },
    { "key": "NOTIF_ID",       "value": "" },
    { "key": "NEW_PRODUCT_ID", "value": "" },
    { "key": "GQL_PRODUCT_ID", "value": "" },
    { "key": "GRPC_ORDER_ID",  "value": "" }
  ],
  "item": [

    {
      "name": "🟦 PRODUCTS — REST",
      "item": [
        {
          "name": "01 — GET Tous les produits",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Réponse est un tableau', () => pm.expect(Array.isArray(body)).to.be.true);",
            "pm.test('Au moins 1 produit', () => pm.expect(body.length).to.be.greaterThan(0));",
            "pm.test('Produit a les champs requis', () => {",
            "  const p = body[0];",
            "  pm.expect(p).to.have.property('id');",
            "  pm.expect(p).to.have.property('name');",
            "  pm.expect(p).to.have.property('price');",
            "  pm.expect(p).to.have.property('stock');",
            "  pm.expect(p).to.have.property('category');",
            "});",
            "if (body.length > 0) pm.collectionVariables.set('PRODUCT_ID', body[0].id);",
            "console.log(' Products count:', body.length);"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/products",
            "description": "Récupère tous les produits. Attendu : 3 produits de démo (Laptop Pro X, Smartphone Y9, Casque Audio Z)."
          }
        },
        {
          "name": "02 — GET Produits filtrés ?q=Laptop",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Résultats filtrent par nom', () => {",
            "  pm.expect(Array.isArray(body)).to.be.true;",
            "  body.forEach(p => pm.expect(p.name.toLowerCase()).to.include('laptop'));",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/products?q=Laptop",
            "description": "Recherche par mot-clé dans name/description."
          }
        },
        {
          "name": "03 — GET Produits par catégorie",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Tous dans catégorie Informatique', () => {",
            "  pm.expect(Array.isArray(body)).to.be.true;",
            "  body.forEach(p => pm.expect(p.category).to.equal('Informatique'));",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/products?category=Informatique"
          }
        },
        {
          "name": "04 — GET Produit par ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
