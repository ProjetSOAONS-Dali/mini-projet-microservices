          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/products/produit-qui-nexiste-vraiment-pas",
            "description": "Test gestion erreur 404."
          }
        },
        {
          "name": "06 — POST Créer un produit",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('Produit créé avec ID', () => {",
            "  pm.expect(body).to.have.property('id');",
            "  pm.expect(body.id).to.be.a('string').with.length.greaterThan(0);",
            "});",
