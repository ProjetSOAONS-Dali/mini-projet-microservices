          "name": "09 — GET Produit supprimé → 404",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404 — bien supprimé', () => pm.response.to.have.status(404));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/products/{{NEW_PRODUCT_ID}}"
          }
        }
      ]
