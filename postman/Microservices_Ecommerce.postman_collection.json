    {
      "name": "🟩 ORDERS — REST",
      "item": [
        {
          "name": "10 — POST Créer une commande (→ Kafka order-created)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.test('Commande créée', () => pm.expect(body).to.be.an('object'));",
            "pm.test('Statut PENDING', () => pm.expect(body.status).to.equal('PENDING'));",
            "pm.test('Total calculé correctement', () => {",
            "  pm.expect(body.total).to.be.a('number').above(0);",
            "  console.log('Total commande:', body.total, 'DT');",
            "});",
            "pm.test('Items présents', () => pm.expect(body.items).to.be.an('array').with.length(2));",
            "pm.test('customer_id correct', () => pm.expect(body.customer_id).to.equal('client-001'));",
            "pm.test('ID commande généré', () => pm.expect(body.id).to.be.a('string').with.length.greaterThan(0));",
            "pm.collectionVariables.set('ORDER_ID', body.id);",
            "console.log('✅ ORDER_ID sauvegardé:', body.id);",
            "console.log('💡 Vérifier console NotificationService → 🔔 ORDER_CREATED');"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/orders",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"client-001\",\n  \"items\": [\n    {\n      \"product_id\": \"p2\",\n      \"product_name\": \"Smartphone Y9\",\n      \"quantity\": 1,\n      \"unit_price\": 799.99\n    },\n    {\n      \"product_id\": \"p3\",\n      \"product_name\": \"Casque Audio Z\",\n      \"quantity\": 2,\n      \"unit_price\": 199.99\n    }\n  ]\n}"
            },
            "description": "⚡ Publie un événement Kafka sur 'order-created'.\nTotal attendu : 799.99 + (2 × 199.99) = 1199.97 DT\nVérifier dans la console NotificationService."
          }
        },
        {
          "name": "11 — GET Commande par ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('ID correspond', () => pm.expect(body.id).to.equal(pm.collectionVariables.get('ORDER_ID')));",
            "pm.test('Items sont un tableau', () => pm.expect(body.items).to.be.an('array'));",
            "pm.test('Statut est PENDING', () => pm.expect(body.status).to.equal('PENDING'));"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/orders/{{ORDER_ID}}"
          }
        },
        {
          "name": "12 — GET Commandes du client",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Tableau retourné', () => pm.expect(Array.isArray(body)).to.be.true);",
            "pm.test('Au moins 1 commande', () => pm.expect(body.length).to.be.greaterThan(0));",
            "console.log('Commandes pour client-001:', body.length);"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/customers/{{CUSTOMER_ID}}/orders"
          }
        },
        {
          "name": "13 — PATCH Statut → CONFIRMED (→ Kafka order-updated)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Statut CONFIRMED', () => pm.expect(body.status).to.equal('CONFIRMED'));",
            "console.log('💡 Vérifier NotificationService → 🔔 ORDER_UPDATED CONFIRMED');"
          ]}}],
          "request": {
            "method": "PATCH",
            "url": "{{BASE_URL}}/orders/{{ORDER_ID}}/status",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\"status\": \"CONFIRMED\"}" },
            "description": "⚡ Publie sur topic 'order-updated'"
          }
        },
        {
          "name": "14 — PATCH Statut → SHIPPED (→ Kafka order-updated)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Statut SHIPPED', () => pm.expect(body.status).to.equal('SHIPPED'));"
          ]}}],
          "request": {
            "method": "PATCH",
            "url": "{{BASE_URL}}/orders/{{ORDER_ID}}/status",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\"status\": \"SHIPPED\"}" }
          }
        },
        {
          "name": "15 — PATCH Statut invalide → erreur",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Statut invalide rejeté (4xx ou 5xx)', () => {",
            "  pm.expect(pm.response.code).to.be.at.least(400);",
            "});",
            "const body = pm.response.json();",
            "pm.test('Erreur présente dans la réponse', () => {",
            "  pm.expect(body.error || body.message || body.success === false).to.be.ok;",
            "});"
          ]}}],
          "request": {
            "method": "PATCH",
            "url": "{{BASE_URL}}/orders/{{ORDER_ID}}/status",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\"status\": \"STATUT_INVALIDE\"}" },
            "description": "Valide que seuls PENDING/CONFIRMED/SHIPPED/DELIVERED/CANCELLED sont acceptés."
          }
        }
      ]
    },

    {
      "name": "🟨 NOTIFICATIONS — REST",
      "item": [
        {
          "name": "16 — GET Notifications du client",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('Tableau retourné', () => pm.expect(Array.isArray(body)).to.be.true);",
            "pm.test('Au moins 3 notifications (Kafka)', () => {",
            "  pm.expect(body.length).to.be.greaterThan(2);",
            "  console.log('Notifications count:', body.length);",
            "  body.forEach(n => console.log(' -', n.type, ':', n.message));",
            "});",
            "pm.test('Structure notification valide', () => {",
            "  const n = body[0];",
            "  pm.expect(n).to.have.property('id');",
            "  pm.expect(n).to.have.property('type');",
            "  pm.expect(n).to.have.property('message');",
            "  pm.expect(n).to.have.property('read');",
            "  pm.expect(n.read).to.be.a('boolean');",
            "});",
            "pm.test('Types valides', () => {",
            "  const validTypes = ['ORDER_CREATED', 'ORDER_UPDATED'];",
            "  body.forEach(n => pm.expect(validTypes).to.include(n.type));",
            "});",
            "if (body.length > 0) pm.collectionVariables.set('NOTIF_ID', body[0].id);"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/notifications/{{CUSTOMER_ID}}",
            "description": "Doit contenir ORDER_CREATED + ORDER_UPDATED (CONFIRMED + SHIPPED) créées automatiquement par Kafka Consumer."
          }
        },
        {
          "name": "17 — PATCH Marquer notification comme lue",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.test('success = true', () => pm.expect(body.success).to.be.true);"
          ]}}],
          "request": {
            "method": "PATCH",
            "url": "{{BASE_URL}}/notifications/{{NOTIF_ID}}/read"
          }
        },
        {
          "name": "18 — GET Vérifier notification marquée lue",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "const notifId = pm.collectionVariables.get('NOTIF_ID');",
            "const notif = body.find(n => n.id === notifId);",
            "pm.test('Notification trouvée', () => pm.expect(notif).to.not.be.undefined);",
            "pm.test('read = true', () => pm.expect(notif.read).to.be.true);"
          ]}}],
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/notifications/{{CUSTOMER_ID}}"
          }
        }
      ]
    },

