              "raw": "{\n  \"name\": \"Écouteurs Pro\",\n  \"description\": \"Écouteurs sans fil avec réduction de bruit active\",\n  \"price\": 89.99,\n  \"stock\": 100,\n  \"category\": \"Audio\"\n}"
            }
          }
        },
