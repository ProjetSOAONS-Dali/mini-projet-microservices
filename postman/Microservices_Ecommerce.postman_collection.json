            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Écouteurs Pro Max\",\n  \"description\": \"Édition Premium avec boîtier de charge\",\n  \"price\": 109.99,\n  \"stock\": 80\n}"
            }
          }
        },
        {
          "name": "08 — DELETE Supprimer le produit créé",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
